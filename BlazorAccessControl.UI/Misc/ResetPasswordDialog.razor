@inject IUserService userService
@inject IJSRuntime js
<button style="@ButtonStyle" class="@ButtonClass" commandfor="@dialogId" command="show-modal">@ButtonText</button>
<dialog id="@dialogId"
        style="min-width: 300px; font-size: 14px; padding: 0px; max-height: calc(100vh - 20px); border: 1px solid gray; border-radius: 8px; box-shadow: 0px 0px 14px -5px rgba(66, 68, 90, 1); width: fit-content; top: 50vh; left: 50vw; margin: 0; transform: translate(-50%, -50%);"
        onmousewheel="return false;">
    <div style="display:flex; flex-direction:column; max-width:90vw; max-height: calc(100vh - 20px);">
        <div ondragover="event.preventDefault();" style="flex: 0 1 auto; background-color:#00000010; border-bottom: 1px solid #00000040; display:flex; align-items:center; padding: 0px 10px 0px 10px; line-height:2rem; position:relative;">
            <div draggable="true" ondragstart="const rect = this.parentNode.parentNode.parentNode.getBoundingClientRect(); window.dialogPos = { posX: rect.left, posY: rect.top, mouseX: event.pageX, mouseY: event.pageY };" ondrag="if (event.screenX == 0) return; let d = this.parentNode.parentNode.parentNode; d.style.removeProperty('transform'); d.style.setProperty('left', (event.pageX - dialogPos.mouseX + dialogPos.posX) + 'px'); d.style.setProperty('top', (event.pageY - dialogPos.mouseY + dialogPos.posY) + 'px');" style="cursor: move; user-select: none; flex-grow: 1;">
                重设密码
            </div>
            <div style="display: flex; align-items:center; gap:10px;">
                <button commandfor="@dialogId" command="close" style="border:none; outline:none; background-color:transparent; padding:4px; font-size:16px; cursor: pointer;">✖</button>
            </div>
        </div>
        <div style="padding:10px;flex: 1 1 auto; overflow-y:auto;">
            <div style="display:flex; flex-direction:column; gap:10px;">
                <div style="display:flex; flex-direction:column; flex-wrap:nowrap; --padding: 4px; ">
                    <span style="display:flex; align-items:center;line-height: 1.2; white-space:nowrap; border: 1px solid gray; border-bottom: none; border-top-left-radius: 4px; border-top-right-radius: 4px; box-sizing:border-box; padding: var(--padding); width:fit-content; background-color: #f0f0f0;  ">
                        新密码
                    </span>
                    <div style="border: 1px solid gray; outline:none; border-radius: 4px; border-top-left-radius: 0px; box-sizing:border-box; font-family:inherit; font-size:inherit; min-width:100%; overflow:hidden; padding: var(--padding);">
                        <input @bind="Password" type="text" autocomplete="off" autocorrect="off" style="border: none; outline: none;width: 100%;height: 100%;background-color: transparent;color: inherit;" />
                    </div>
                </div>
            </div>
        </div>
        <div style="flex: 0 1; background-color:#00000010; padding:4px 10px 4px 10px; border-top:1px solid #00000040;">
            <div style="display:flex; gap:10px;">
                <button @onclick="Confirm" commandfor="@dialogId" command="close" style="border: 1px solid gray; padding: 0.2rem 0.4rem; border-radius: 6px;">
                    确定
                </button>
                <div style="flex-grow: 1"></div>
                <button commandfor="@dialogId" command="close" style="border: 1px solid gray; padding: 0.2rem 0.4rem; border-radius: 6px;">
                    取消
                </button>
            </div>
        </div>
    </div>
</dialog>

@code {
    [Parameter]
    public EventCallback OnChange { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter, EditorRequired]
    public string ButtonText { get; set; }

    [Parameter]
    public string? ButtonClass { get; set; }

    [Parameter]
    public string? ButtonStyle { get; set; }

    [Parameter, EditorRequired]
    public string UserId { get; set; }

    private string? Password;

    private string dialogId = $"dialog_{Guid.NewGuid().ToString()}";

    private async Task Confirm()
    {
        try
        {
            var user = await userService.GetUserByIdAsync(UserId);
            if (user is null) throw new Exception("User Not Found");
            await userService.ResetPasswordAsync(user, Password ?? string.Empty);
            Password = null;
            await js.InvokeVoidAsync("alert", "Password has been reset.");
        }
        catch(Exception ex)
        {
            await js.InvokeVoidAsync("alert", ex.ToString());
        }
        if (OnChange.HasDelegate == false) return;
        await OnChange.InvokeAsync();
    }
}
