<button style="@ButtonStyle" class="@ButtonClass" commandfor="@dialogId" command="show-modal">@ButtonText</button>
<dialog id="@dialogId" style="margin:auto; border: 1px solid rgb(222, 226, 230); border-radius: 6px;">
    <div style="padding: 1rem; display: grid; grid-template: 100% 50% 50%; gap: 1rem;">
        <p style="grid-column: 1 / 3; grid-row: 1;">@Message</p>
        <button class="button" @onclick="Confirm" commandfor="@dialogId" command="close" style="grid-column: 1 / 1; grid-row: 2; ">确定</button>
        <button class="button" commandfor="@dialogId" command="close" style="grid-column: 2 / 2; grid-row: 2; ">取消</button>
    </div>
</dialog>

@code {
    [Parameter]
    public EventCallback OnConfirm { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter, EditorRequired]
    public string ButtonText { get; set; }

    [Parameter]
    public string? ButtonClass { get; set; }

    [Parameter]
    public string? ButtonStyle { get; set; }

    [Parameter, EditorRequired]
    public string Message { get; set; }

    private string dialogId = $"dialog_{Guid.NewGuid().ToString()}";

    private async Task Confirm()
    {
        if (OnConfirm.HasDelegate == false) return;
        await OnConfirm.InvokeAsync();
    }
}
